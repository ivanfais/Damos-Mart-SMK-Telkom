NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# Replace with your Railway PostgreSQL connection string for production.
DATABASE_URL=postgresql://postgres:postgres@<railway-postgres-host>:5432/damos_mart?schema=public

# Redis
# Replace with your Railway Redis connection string for production.
REDIS_URL=redis://<railway-redis-host>:6379

# JWT Secrets
JWT_ACCESS_SECRET=damos_mart_access_secret_key_12345_dev
JWT_REFRESH_SECRET=damos_mart_refresh_secret_key_67890_dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:51282,http://localhost:55583,http://localhost:61093,https://damos-mart-smk-telkom-production.up.railway.app

# API Configuration
API_PREFIX=/api/v1

# Email (SMTP) — kosongkan di development; link reset dicetak ke console backend
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Damos Mart <noreply@damosmart.com>

# Sesuaikan port Flutter web (lihat URL browser saat flutter run)
RESET_PASSWORD_URL=https://damos-mart-smk-telkom-production.up.railway.app/reset-password?token=
