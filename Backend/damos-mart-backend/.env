NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/damos_mart?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_ACCESS_SECRET=damos_mart_access_secret_key_12345_dev
JWT_REFRESH_SECRET=damos_mart_refresh_secret_key_67890_dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:55583,http://localhost:61093

# API Configuration
API_PREFIX=/api/v1
