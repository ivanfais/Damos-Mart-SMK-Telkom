NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/damos_mart?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# CORS — comma-separated frontend URLs (include staging Netlify URL after deploy)
# Example: https://damos-mart.netlify.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# API
API_PREFIX=/api/v1

# Email (SMTP) — optional in development; reset link is logged to console if unset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Damos Mart <noreply@damosmart.com>

# Fallback reset URL for all DISC apps (email link opens this web page)
# Contoh: https://damos-mart-dominance.netlify.app/reset-password?token=
RESET_PASSWORD_URL=http://localhost:8080/reset-password?token=

# Optional per-variant overrides (jika tiap app punya URL web sendiri)
# RESET_PASSWORD_URL_DOMINANCE=
# RESET_PASSWORD_URL_INFLUENCE=
# RESET_PASSWORD_URL_STEADINESS=
# RESET_PASSWORD_URL_CONSCIENTIOUSNESS=

# Legacy demo code (kosongkan — semua app memakai link email)
PASSWORD_RESET_DEMO_CODE=
